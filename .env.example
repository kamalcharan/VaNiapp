# ═══════════════════════════════════════════════════════════════
# VaNi App — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# VaNi now uses its OWN dedicated Supabase project.
# Get these from: https://supabase.com/dashboard → Your VaNi Project → Settings → API
# ═══════════════════════════════════════════════════════════════

# Supabase Configuration (VaNi's own project)
EXPO_PUBLIC_SUPABASE_URL=https://your-vani-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth (used for Supabase Google sign-in)
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Remember to add the new Supabase callback URL to Authorized redirect URIs:
#   https://your-vani-project-id.supabase.co/auth/v1/callback
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OpenAI API Key (for Ask VaNi AI doubt solver)
# Get from: https://platform.openai.com/api-keys
# For production, move to Supabase Edge Function instead.
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-api-key-here

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# ═══════════════════════════════════════════════════════════════
# Data Migration (only needed during migration from shared DB)
# Used by: scripts/migrate-data.mjs
# Remove these after migration is complete.
# ═══════════════════════════════════════════════════════════════
# OLD_SUPABASE_URL=https://old-shared-project.supabase.co
# OLD_SUPABASE_SERVICE_KEY=your-old-service-role-key
# NEW_SUPABASE_URL=https://your-vani-project-id.supabase.co
# NEW_SUPABASE_SERVICE_KEY=your-new-service-role-key
