{
  "expo": {
    "name": "VaNi",
    "slug": "vani",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "vani",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdfcf0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vikuna.vaniapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground-1024.png",
        "backgroundColor": "#fdfcf0"
      },
      "package": "com.vikuna.vaniapp",
      "targetSdkVersion": 34,
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro"
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "organization": "vikuna",
          "project": "vani-app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "951d48b6-7878-49c7-8d39-ab5e801a02ae"
      }
    }
  }
}
